# Generated nginx site configs
/config/nginx/sites/*

# Backups
/backups/*

# Generated configs (auto-optimize.sh overwrites defaults per-server)
# Default configs ARE tracked in git so `git clone && build` works out of the box.
# auto-optimize.sh generates optimized versions that override defaults.
# To avoid committing optimized configs, run: git update-index --skip-worktree <file>

# Local override
