# ============================================================================
# MARIADB 10.11 CONFIGURATION FOR BITRIX - PRODUCTION
# Оптимизировано для: высокая нагрузка, 64GB RAM сервер
# ============================================================================

[mysqld]
# ============================================================================
# ОСНОВНЫЕ НАСТРОЙКИ
# ============================================================================
bind-address = 0.0.0.0
port = 3306
datadir = /var/lib/mysql
socket = /var/run/mysqld/mysqld.sock
pid-file = /var/run/mysqld/mysqld.pid

# Timezone
default-time-zone = "+03:00"

# Пропускаем разрешение имен хостов
skip-name-resolve = 1

# Server ID
server-id = 1

# ============================================================================
# КОДИРОВКА
# ============================================================================
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci
init-connect = "SET NAMES utf8mb4"

# ============================================================================
# INNODB НАСТРОЙКИ (для 64GB RAM сервера)
# ============================================================================
innodb_strict_mode = OFF
innodb_file_per_table = 1

# Буфер пул: ~70% от RAM = ~45GB для 64GB сервера
# Но нужно учитывать другие сервисы, ставим 32GB
innodb_buffer_pool_size = 32G

# Прогрев буфер пула при старте
innodb_buffer_pool_dump_at_shutdown = 1
innodb_buffer_pool_load_at_startup = 1

# Метод flush
innodb_flush_method = O_DIRECT

# Flush лога (2 = Bitrix recommended)
innodb_flush_log_at_trx_commit = 2

# Redo log (MariaDB syntax)
innodb_log_file_size = 2G

# Буфер для лога
innodb_log_buffer_size = 256M

# Timeout для блокировок
innodb_lock_wait_timeout = 50

# IO настройки (для SSD)
innodb_io_capacity = 4000
innodb_io_capacity_max = 8000
innodb_read_io_threads = 16
innodb_write_io_threads = 16

# Flush neighbors (0 для SSD)
innodb_flush_neighbors = 0

# Temporary tablespace
innodb_temp_data_file_path = ibtmp1:12M:autoextend:max:20G

# ============================================================================
# ПРОИЗВОДИТЕЛЬНОСТЬ
# ============================================================================
max_connections = 500
thread_cache_size = 200
thread_stack = 512K

# Кэш таблиц
table_open_cache = 8000
table_definition_cache = 4000
table_open_cache_instances = 32

# Буферы (увеличены для исправления проблемы с временными таблицами на диске)
sort_buffer_size = 8M
join_buffer_size = 8M
read_buffer_size = 4M
read_rnd_buffer_size = 16M

# Временные таблицы (увеличены для исправления 33% на диске)
tmp_table_size = 512M
max_heap_table_size = 512M

# Максимальный размер пакета
max_allowed_packet = 256M

# Буфер для MyISAM
key_buffer_size = 256M

# ============================================================================
# BITRIX СПЕЦИФИЧНЫЕ НАСТРОЙКИ
# ============================================================================
transaction-isolation = READ-COMMITTED
sql_mode = ""

# Binary logging отключен
skip-log-bin = 1

# ============================================================================
# ЛОГИРОВАНИЕ (минимальное для prod, stderr для Docker)
# ============================================================================
# General log - отключен в prod
general_log = 0

# Error log - НЕ задаём, пусть пишет в stderr (Docker logs)
# НЕ использовать log_error = /var/log/mysql/... - permission denied в контейнере
# Все логи ошибок автоматически идут в docker logs

# Slow query log - отключен (можно включить для диагностики)
slow_query_log = 0
long_query_time = 3

# ============================================================================
# БЕЗОПАСНОСТЬ
# ============================================================================
local_infile = 0
max_connect_errors = 10000

# ============================================================================
# TIMEOUTS
# ============================================================================
interactive_timeout = 7200
wait_timeout = 7200
connect_timeout = 10

# ============================================================================
# ПРОЧИЕ НАСТРОЙКИ
# ============================================================================
lower_case_table_names = 0

# Performance Schema
performance_schema = ON
performance-schema-instrument = 'stage/%=ON'
performance-schema-consumer-events-stages-current = ON
performance-schema-consumer-events-stages-history = ON

[mysql]
default-character-set = utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet = 256M
single-transaction

[client]
port = 3306
socket = /var/run/mysqld/mysqld.sock
default-character-set = utf8mb4
